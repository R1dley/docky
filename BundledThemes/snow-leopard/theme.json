{
  "schemaVersion": 1,
  "id": "snow-leopard",
  "name": "Snow Leopard",
  "author": "Docky",
  "version": "1.0.0",
  "description": "A faithful Snow Leopard recreation: classic chrome with sprite background, custom dividers, and a curated set of per-app icons from the Leopard Snow pack.",
  "appearance": {
    "disablesGlassLook": true,
    "indicators": {
      "divider": {
        "center": "assets/DOCKSeparatorTile.png",
        "imageScale": 1,
        "left": "assets/DOCKSeparatorTile.png",
        "mirrorLeftOnRight": false,
        "offset": 0,
        "paddingFraction": 0,
        "right": "assets/DOCKSeparatorTile.png"
      },
      "image": "assets/indicator_large.png",
      "offset": -9,
      "scale": 1.75,
      "shape": "image"
    },
    "tile": {
      "clipShape": "rounded",
      "spacing": 0,
      "verticalPadding": 8
    },
    "window": {
      "backgroundImage": "assets/background1.png",
      "backgroundImageMode": "sprite",
      "clipShape": "rounded",
      "cornerRadius": 0,
      "tintOpacity": 0
    }
  }
}
